{
  "name": "mediccon-lis",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "description": "Mediccon Laboratory Information System with HL7/ASTM Support",
  "scripts": {
    "start": "cmd /C \"set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "build": "node compiler.js && electron-builder",
    "pack": "node compiler.js && electron-builder --dir",
    "rebuild": "npx @electron/rebuild --force --types better-sqlite3,serialport"
  },
  "build": {
    "appId": "com.mediccon.lis",
    "productName": "Mediccon LIS Core",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mediccon LIS"
    },
    "extraResources": [
      "src/database/**/*",
      "src/config/**/*"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "electron-log": "^5.0.0",
    "jsbarcode": "^3.11.6",
    "lucide-react": "^0.344.0",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.4",
    "react-speech-recognition": "^4.0.1",
    "recharts": "^3.8.0",
    "regenerator-runtime": "^0.14.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^3.4.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.3"
  }
}
